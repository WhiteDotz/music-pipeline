# Copy to ~/.lb-sync.env and chmod 600. Read by the playlist/star sync tools.
# The scripts source this instead of taking credentials as arguments — a
# password in a crontab line is a password in every `ps` listing.

LB_USER=your-listenbrainz-user
LB_TOKEN=your-listenbrainz-token

# Navidrome (Subsonic API). Authentication is a salted MD5 token derived from
# the password, so the plaintext is needed at call time — that is the protocol's
# design, not a hashing choice made here.
NAVIDROME_BASE=http://localhost:4533
NAVIDROME_USER=admin
NAVIDROME_PASS=your-navidrome-password

# Navidrome's SQLite DB, read directly (read-only) for library queries.
NAVIDROME_DB=/path/to/navidrome/navidrome.db

# Music library root, read by the playlist generators.
MUSIC_DIR=/path/to/Music
